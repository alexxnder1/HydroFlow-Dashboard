{
  "version": "2.0.0",
  "tasks": [
    {
      "type": "npm",
      "script": "build",
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": []
    },
  {
    "label": "Live Reload",
    "type": "shell",
    "command": " npx cap run android --live-reload --host=192.168.0.83 --port=5173",
    "problemMatcher": [],
    "group": "none",
    "presentation": {
      "echo": true,
      "reveal": "always",
      "focus": true,
      "panel": "shared"
    }
  },
    {
      "label": "Build and Send APK",
      "type": "shell",
      "command": "npm run build && npx cap sync android && cd android && .\\gradlew assembleDebug && cd .. && \"%LOCALAPPDATA%\\Android\\Sdk\\platform-tools\\adb.exe\" install -r android/app/build/outputs/apk/debug/app-debug.apk",      "problemMatcher": [],
      "options": {
        "env": {
          "JAVA_HOME": "C:\\Program Files\\Android\\Android Studio\\jbr"
        }
      },
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": true,
        "panel": "shared",
        "showReuseMessage": true,
        "clear": false
      }
    }
  ]
}